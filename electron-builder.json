{
  "appId": "local.wmux.app",
  "productName": "wmux",
  "directories": {
    "output": "release"
  },
  "afterPack": "scripts/after-pack.cjs",
  "files": [
    "dist/**/*",
    "node_modules/**/*",
    "!**/*.ts",
    "!**/*.tsx",
    "!src/**/*",
    "!docs/**/*",
    "!tests/**/*"
  ],
  "asarUnpack": [
    "**/*.node"
  ],
  "win": {
    "icon": "resources/icons/icon.ico",
    "signAndEditExecutable": false,
    "target": [
      { "target": "dir", "arch": ["x64"] },
      { "target": "nsis", "arch": ["x64"] }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "wmux"
  },
  "portable": {
    "artifactName": "wmux-${version}-portable.exe"
  },
  "extraResources": [
    { "from": "resources/icon.png", "to": "icon.png" },
    { "from": "resources/themes", "to": "themes" },
    { "from": "resources/sounds", "to": "sounds" },
    { "from": "src/shell-integration", "to": "shell-integration" },
    { "from": "dist/cli/wmux.js", "to": "cli/wmux.js" }
  ]
}
